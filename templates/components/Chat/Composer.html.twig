<div class="sticky bottom-0 z-10 mx-auto w-full bg-background px-4 pb-4 sm:px-6 md:max-w-3xl lg:px-8">
    <div id="chat-form" class="rounded-3xl border border-line-3 bg-layer px-2 pb-2 shadow-xs">
        <label for="chat-textarea" class="sr-only">Ask anything...</label>

        <textarea id="chat-textarea" class="mt-2 block overflow-y-auto max-h-36 [&::-webkit-scrollbar]:w-2 w-full [&::-webkit-scrollbar-thumb]:rounded-none border-transparent bg-transparent [&::-webkit-scrollbar-thumb]:bg-scrollbar-thumb pb-2 pt-4 ps-2 pe-4 placeholder:text-muted-foreground-1 text-foreground resize-none focus:border-transparent focus:outline-hidden focus:ring-transparent disabled:opacity-50 disabled:pointer-events-none" placeholder="Ask anything..." data-hs-textarea-auto-height></textarea>

        <div class="flex items-center justify-between pt-2">
            {# New Conversation #}
            <div class="[--placement:top] hs-tooltip inline-block">
                <a href="{{ path('app_chat_index') }}" class="hs-tooltip-toggle flex size-9 items-center justify-center rounded-full text-sm text-foreground focus:outline-hidden focus:bg-muted-focus hover:bg-muted-hover">
                    {{ ux_icon('tabler:message-plus', {class: 'shrink-0 size-4.5'}) }}
                    <span class="hs-tooltip-content absolute hs-tooltip-shown:visible invisible z-10 inline-block rounded-md border border-tooltip-line bg-tooltip px-2 py-1 text-xs font-medium text-tooltip-foreground opacity-0 hs-tooltip-shown:opacity-100 shadow-2xs transition-opacity" role="tooltip">
                        New chat
                    </span>
                </a>
            </div>

            {# Send / Stop #}
            <button id="chat-send" type="button" data-mode="idle" class="inline-flex w-20 shrink-0 items-center justify-center gap-1 rounded-full border border-primary-line bg-primary py-2 pr-1 text-sm font-medium font-mono text-primary-foreground tracking-tight focus:outline-hidden focus:bg-primary-focus hover:bg-primary-hover disabled:opacity-50 disabled:pointer-events-none">
                <span data-icon-send>{{ ux_icon('tabler:arrow-up', {class: 'shrink-0 size-4.5'}) }}</span>
                <span data-icon-stop class="hidden">{{ ux_icon('tabler:player-stop', {class: 'shrink-0 size-4'}) }}</span>
                <span data-send-label>Send</span>
                <span data-stop-label class="hidden">Stop</span>
            </button>
        </div>
    </div>
</div>
