<header{{attributes}} class="fixed inset-x-0 top-0 z-48 flex flex-wrap bg-navbar py-2.5 transition-all duration-300 md:flex-nowrap md:justify-start">
	<nav
		class="mx-auto flex w-full basis-full items-center justify-between px-4 sm:px-5.5">
		{# GitHub Link #}
		<a href="https://github.com/LiamBdr/symfony-ai-lab" target="_blank" rel="noopener" class="flex size-8 items-center justify-center rounded-full text-layer-foreground/70 transition-colors hover:bg-surface hover:text-layer-foreground" aria-label="GitHub repository">
			{{ ux_icon('tabler:brand-github', {class: 'shrink-0 size-4.5'}) }}
		</a>
		{# End GitHub Link #}

		{# Button Group #}
		<div class="flex items-center sm:gap-x-1.5">
			{# Theme Switch #}
			<div class="inline-flex rounded-full bg-surface p-0.5 cursor-pointer">
				<button type="button" class="flex size-7 items-center justify-center rounded-full hs-auto-mode-active:bg-transparent hs-dark-mode-active:bg-transparent bg-layer text-layer-foreground shadow-sm hs-auto-mode-active:shadow-none hs-dark-mode-active:shadow-none" data-hs-theme-click-value="default">
					{{ ux_icon('tabler:sun', {class: 'shrink-0 size-4'}) }}
					<span class="sr-only">Default (Light)</span>
				</button>
				<button type="button" class="flex size-7 items-center justify-center rounded-full hs-dark-mode-active:bg-secondary-active hs-dark-mode-active:text-secondary-foreground text-layer-foreground hs-dark-mode-active:shadow-sm" data-hs-theme-click-value="dark">
					{{ ux_icon('tabler:moon', {class: 'shrink-0 size-4'}) }}
					<span class="sr-only">Dark</span>
				</button>
			</div>
			{# End Theme Switch #}
		</div>
		{# End Button Group #}
	</nav>
</header>
